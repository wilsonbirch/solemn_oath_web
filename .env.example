# --- Sanity ---
# From sanity.io/manage after creating a project (see README setup section).
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token (only required if using draft/preview content from Server Components).
# Leave blank for now — we only fetch published content.
SANITY_API_READ_TOKEN=

# --- Site ---
# Used for absolute URLs (sitemap, OG images, metadataBase).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (contact form, PR 8) ---
# Get from resend.com/api-keys. Form silently logs to server console
# if these are blank.
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=
CONTACT_FORM_FROM_EMAIL="Solemn Oath <onboarding@resend.dev>"

# --- SEO (PR 9) ---
# Set to "true" ONLY when ready to allow search engines to crawl the
# deployed site. Until then the layout sends noindex and the sitemap
# is empty.
SEO_INDEX=false

# --- Analytics (PR 9, optional) ---
# Plausible: register the site at plausible.io and put the domain here.
# Only loads in production builds.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Override only if you self-host Plausible.
NEXT_PUBLIC_PLAUSIBLE_SRC=
