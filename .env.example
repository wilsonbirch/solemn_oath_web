# --- Sanity ---
# From sanity.io/manage after creating a project (see README setup section).
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token (only required if using draft/preview content from Server Components).
# Leave blank for now — we only fetch published content.
SANITY_API_READ_TOKEN=

# --- Site ---
# Used for absolute URLs (sitemap, OG images, metadataBase).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (PR 8 — contact form) ---
# Get from resend.com/api-keys. Not required until PR 8 lands.
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=
